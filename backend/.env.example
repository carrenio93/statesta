# Statesta sync worker — secrets template.
# Copy this file to `.env` in the same folder (backend/.env) and fill in the values.
# `.env` is gitignored (never commit real secrets). This `.env.example` holds NO real values.

# ---------------------------------------------------------------------------
# DATABASE_URL — Supabase Postgres connection string.
#
# IMPORTANT: use the SESSION POOLER or the DIRECT connection (port 5432).
# Do NOT use the transaction pooler (port 6543): the sync worker runs
# multi-statement transactions and uses RETURNING, which the transaction
# pooler does not support reliably.
#
# Find it in: Supabase Dashboard -> Project -> Connect.
#   Session pooler (recommended; IPv4-friendly), port 5432:
#     postgresql://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:5432/postgres
#   Direct connection, port 5432:
#     postgresql://postgres:<db-password>@db.<project-ref>.supabase.co:5432/postgres
DATABASE_URL=

# ---------------------------------------------------------------------------
# API_FOOTBALL_KEY — your API-Football (api-sports.io) API key.
# Find it in: dashboard.api-football.com -> Account (the "API Key" value).
# It is a long alphanumeric string, e.g. 0123456789abcdef0123456789abcdef
API_FOOTBALL_KEY=
